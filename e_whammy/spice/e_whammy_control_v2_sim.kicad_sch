	(text "Sensor Input Simulation"
		(exclude_from_sim no)
		(at 49.53 142.24 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left)
		)
		(uuid "182703b6-1513-44d9-8526-658cbcaf9801")
	)
	(text "RESET WITH LATCH-RECOVERY LOGIC\nRESET = WINDOW  OR  STARTUP  OR  TIMEOUT\n\n-STARTUP (R21/C20): ramps low-to-high at power-on; \nwhile low it forces RESET high so the servo acquires \ncenter on power-up.\n\n-WINDOW (comparators): high when OUT is inside the \nreset window around VREF, low when outside. RESET \nfollows it - inside = correct, a bend = hold.\n\n-TIMEOUT (D1/R22 charge, D2/R23 decay, C21): an \nasymmetric envelope off WINDOW (fast in, slow out). \nIf OUT stays outside the window much longer than \nany real bend (~20 s), it forces RESET high to \nre-acquire center, breaking a latch-up."
		(exclude_from_sim no)
		(at 165.1 181.61 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "2994640f-5893-477c-b375-a931ac8ca26d")
	)
	(text "DC Servo"
		(exclude_from_sim no)
		(at 49.53 48.26 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left)
		)
		(uuid "6edd9aa5-8c2f-4a20-bf93-ef54411eb4e1")
	)
	(text "Raw Hall SENSOR model, before final 5 V \noutput scaling.\n* Center is 2.175 V.\n* Startup includes deliberate small motion \n  during reset acquisition.\n* Large up bend: 2.175 V -> 2.425 V, then \n  releases to 2.1825 V\n  to model +7.5 mV spring hysteresis.\n* Large down bend: 2.1825 V -> 1.925 V, \n  then releases to 2.1675 V\n  to model the opposite hysteresis direction.\n* Pitch range is ±12 semitones: 1 \n  semitone = 20.8333 mV at SENSOR.\n* Then test +1 semitone hold, center, \n  -1 semitone hold, center.\n  Each semitone test is 100 ms ramp, \n  800 ms hold, 100 ms return.\n* Final test is 5 Hz vibrato, ±10 mV \n  around 2.1675 V."
		(exclude_from_sim no)
		(at 80.645 167.64 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "7112f564-d2be-4547-9ccc-aee108702932")
	)
	(text "Threshold Modulation"
		(exclude_from_sim no)
		(at 280.67 109.855 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "73acdd80-589e-4842-bfe3-15c8d0ea5e4b")
	)
	(text "1: Inside window\n0: Outside window \n\nNote: Open Drain. \n"
