	)
	(text "A simplified raw Hall sensor source in the pre-gain domain, \nnot the final 5 V output domain.\n* Resting baseline is 2.175 V.\n* A large upward bend ramps to 2.425 V and holds briefly.\n* After release, the signal returns to 2.1825 V, modeling \n  a +7.5 mV spring-hysteresis center shift.\n* A matching large downward bend ramps to 1.925 V, holds, \n  and returns to 2.1675 V before vibrato begins.\n* After a short delay, a 5 Hz vibrato of ±10 mV is applied \n  around 2.1675 V for a limited duration, then stops.\n* This model was chosen to test bend handling, return behavior, \n  hysteresis cleanup, and vibrato preservation under realistic \n  raw-sensor conditions."
		(exclude_from_sim no)
		(at 56.515 198.12 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "7112f564-d2be-4547-9ccc-aee108702932")
	)
	(text "1: Inside window\n0: Outside window \n"
		(exclude_from_sim no)
		(at 249.555 83.82 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "782b481e-4e57-4b4d-9e9c-b12e96a92001")
	)
