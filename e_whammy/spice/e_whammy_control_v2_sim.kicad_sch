			)
		)
		(uuid "592c1039-1566-486b-a2b9-0aa590bd889b")
	)
	(text "Raw Hall SENSOR model, before final 5 V output scaling.\n* Center is 2.175 V.\n* Startup includes deliberate small motion during reset acquisition.\n* Large up bend: 2.175 V -> 2.425 V, then releases to 2.1825 V\n  to model +7.5 mV spring hysteresis.\n* Large down bend: 2.1825 V -> 1.925 V, then releases to 2.1675 V\n  to model the opposite hysteresis direction.\n* Pitch range is ±12 semitones: 1 semitone = 20.8333 mV at SENSOR.\n* Then test +1 semitone hold, center, -1 semitone hold, center.\n  Each semitone test is 100 ms ramp, 800 ms hold, 100 ms return.\n* Final test is 5 Hz vibrato, ±10 mV around 2.1675 V."
		(exclude_from_sim no)
		(at 54.61 152.4 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "7112f564-d2be-4547-9ccc-aee108702932")
	)
	(text "1: Inside window\n0: Outside window \n"
		(exclude_from_sim no)
		(at 280.67 87.63 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "782b481e-4e57-4b4d-9e9c-b12e96a92001")
	)
